#!/bin/sh
## 2025-01-09 SARBS
# Abh√§ngigkeiten: GNU Coreutils (cat, cut, date, stat), curl, notify-send, setsid

# Shows the current moon phase with detailed Nerd Font icons.

moonfile="${XDG_DATA_HOME:-$HOME/.local/share}/moonphase"

# Hole Mondtag von wttr.in und mappe auf Icon
if ! [ -s "$moonfile" ] || [ "$(stat -c %y "$moonfile" 2>/dev/null | cut -d' ' -f1)" != "$(date '+%Y-%m-%d')" ]; then
	moonday="$(curl -sf "wttr.in/?format=%M")" || exit 1

	# Mappe Mondtag (0-29) auf Nerd Font Icons
	case "$moonday" in
		0)  icon="оПИ" ;;
		1)  icon="оПЙ" ;;
		2)  icon="оПК" ;;
		3)  icon="оПЛ" ;;
		4)  icon="оПМ" ;;
		5)  icon="оПН" ;;
		6)  icon="оПО" ;;
		7)  icon="оПП" ;;
		8)  icon="оПР" ;;
		9)  icon="оПС" ;;
		10) icon="оПТ" ;;
		11) icon="оПУ" ;;
		12) icon="оПФ" ;;
		13) icon="оПХ" ;;
		14) icon="оПЦ" ;;
		15) icon="оПЧ" ;;
		16) icon="оПШ" ;;
		17) icon="оПЩ" ;;
		18) icon="оПЪ" ;;
		19) icon="оПЫ" ;;
		20) icon="оПЬ" ;;
		21) icon="оПЭ" ;;
		22) icon="оПЮ" ;;
		23) icon="оПЯ" ;;
		24) icon="оП†" ;;
		25) icon="оП°" ;;
		26) icon="оПҐ" ;;
		27) icon="оП£" ;;
		28|29) icon="оП£" ;;
		*) exit 1 ;;
	esac

	# Schreibe Icon in Datei
	printf "%s" "$icon" > "$moonfile"
fi

icon="$(cat "$moonfile")"

# Bestimme Name basierend auf Icon
case "$icon" in
	"оПИ") name="Neumond" ;;
	"оПЙ") name="Zunehmende Sichel 1" ;;
	"оПК") name="Zunehmende Sichel 2" ;;
	"оПЛ") name="Zunehmende Sichel 3" ;;
	"оПМ") name="Zunehmende Sichel 4" ;;
	"оПН") name="Zunehmende Sichel 5" ;;
	"оПО") name="Zunehmende Sichel 6" ;;
	"оПП") name="Erstes Viertel" ;;
	"оПР") name="Zunehmender Mond 1" ;;
	"оПС") name="Zunehmender Mond 2" ;;
	"оПТ") name="Zunehmender Mond 3" ;;
	"оПУ") name="Zunehmender Mond 4" ;;
	"оПФ") name="Zunehmender Mond 5" ;;
	"оПХ") name="Zunehmender Mond 6" ;;
	"оПЦ") name="Vollmond" ;;
	"оПЧ") name="Abnehmender Mond 1" ;;
	"оПШ") name="Abnehmender Mond 2" ;;
	"оПЩ") name="Abnehmender Mond 3" ;;
	"оПЪ") name="Abnehmender Mond 4" ;;
	"оПЫ") name="Abnehmender Mond 5" ;;
	"оПЬ") name="Abnehmender Mond 6" ;;
	"оПЭ") name="Letztes Viertel" ;;
	"оПЮ") name="Abnehmende Sichel 1" ;;
	"оПЯ") name="Abnehmende Sichel 2" ;;
	"оП†") name="Abnehmende Sichel 3" ;;
	"оП°") name="Abnehmende Sichel 4" ;;
	"оПҐ") name="Abnehmende Sichel 5" ;;
	"оП£ ") name="Abnehmende Sichel 6" ;;
	*) name="Unbekannt" ;;
esac

echo "${icon} "

case $BLOCK_BUTTON in
	3) notify-send "пЖЖ Mondphasen Modul" "Zeigt die aktuelle Mondphase an.

Phase: ${name}

28 detaillierte Mondphasen mit Nerd Font Icons" ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

