#!/bin/sh
## 2025-03-06 SARBS
# Abhﾃ､ngigkeiten: GNU Coreutils (date, tr), cal, calcurse, notify-send, sed, setsid

clock=$(date '+%I')

case "$clock" in
	"00") icon="暿走 " ;;
	"01") icon="暿窓 " ;;
	"02") icon="暿糟 " ;;
	"03") icon="暿総 " ;;
	"04") icon="暿綜 " ;;
	"05") icon="暿聡 " ;;
	"06") icon="暿草 " ;;
	"07") icon="暿荘 " ;;
	"08") icon="暿葬 " ;;
	"09") icon="暿蒼 " ;;
	"10") icon="暿藻 " ;;
	"11") icon="暿装 " ;;
	"12") icon="暿走 " ;;
esac

case $BLOCK_BUTTON in
	1) notify-send --urgency=normal "Dieser Monat" "$(cal | sed "s/¥<$(date +'%e'|tr -d ' ')¥>/<b><span color='red'>&<¥/span><¥/b>/")" && notify-send --urgency=critical "Termine" "$(calcurse -d30)" ;;
	2) setsid -f "$TERMINAL" -e calcurse ;;
	3) notify-send "諴ｰ Zeit-/Datumsmodul" "¥- L-㬚鎖 um bevorstehende Termine und Monat
- M-㬚鎖 ﾃｶffnet calcurse" ;;
    4) ;;
    5) ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

date "+%H:%M"
