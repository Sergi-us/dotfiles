#!/bin/sh
## 2025-02-10 SARBS

# Funktioniert auf jedem Init-System
# Abhängigkeiten: rofi, xorg-setxkbmap

rofi_menu() {
    rofi -dmenu -i -location 0 -theme-str 'window { width: 30%; } listview { lines: 15; }' "$@"
}

kb="$(setxkbmap -query | grep -oP 'layout:\s*\K\w+')" || exit 1

case $BLOCK_BUTTON in
	1) 
		kb_choice="$(awk '/! layout/{flag=1; next} /! variant/{flag=0} flag {print $2, "- " $1}' /usr/share/X11/xkb/rules/base.lst | rofi_menu -p "Tastaturlayout:")"
		[ -z "$kb_choice" ] && exit 0
		kb="$(echo "$kb_choice" | awk '{print $3}')"
		setxkbmap "$kb"
		pkill -RTMIN+25 "${STATUSBAR:-dwmblocks}"
		;;
	3) notify-send "⌨  Tastatur/Sprachmodul" "$(printf "%s" "\- Aktuelles Layout: $(setxkbmap -query | grep -oP 'layout:\s*\K\w+')")
- Linksklick zum Ändern der Tastatur."
		;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

echo "[$kb]"