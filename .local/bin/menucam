#!/bin/sh
## 2025-02-10 SARBS
# Webcam-Script mit Rofi-Abfrage

# Konfigurationsvariablen
ANDROID_RESOLUTION="1920x1080"
# STANDARD_RESOLUTION="1080x1080"
PIXELFORMAT="MJPG"

# Reduzierte GPU-Optionen fÃžr mpv
MPV_BASE_OPTIONS="--untimed --no-cache --no-osc --no-input-default-bindings --profile=low-latency --input-conf=/dev/null --title=webcam"
# STANDARD_FILTERS="crop=1080:1080,scale=1080:1080,hflip"
STANDARD_FILTERS="crop=1080:1080,scale=1080:1080"
ANDROID_FILTERS="rotate=PI/2,hue=s=0,crop=1080:1080,hflip,vflip"
ANDROID_ROTATION=""

# HINWEIS ZU MEHREREN DEVICES PRO KAMERA:
# Es ist normal, dass eine Webcam mehrere /dev/video* Nodes erstellt.
# Grund ist der Video4Linux2 (V4L2) Treiber:
# - video0: Meist der 'Video Capture Node' (Der echte Bild-Stream fÃžr mpv).
# - video1: Meist der 'Metadata Node' (z.B. fÃžr Hardware-Autofokus oder Belichtung).
#           Hier schlÃĪgt mpv fehl, da es keine echten Bilddaten sind.
# Wir listen bewusst alle auf, falls der Capture-Node abweicht.

# AbhÃĪngigkeiten prÃžfen
for cmd in v4l2-ctl mpv rofi; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        notify-send -u critical "Fehlende AbhÃĪngigkeit" "Bitte installiere '$cmd' fÃžr das Webcam-Skript."
        exit 1
    fi
done

# Funktion zum Auflisten aller verfÃžgbaren VideogerÃĪte mit bereinigtem Namen
list_video_devices() {
    # v4l2-ctl listet GerÃĪte im Format:
    # Integrated Camera: Integrated C (usb-0000:07:00.4-2.1):
    #         /dev/video0
    # Wir extrahieren den Namen VOR der Klammer (usb-...)
    v4l2-ctl --list-devices | awk '
        /^\t\/dev\/video/ { if(name != "") print $1 " [" name "]" }
        /^[^[:space:]]/ {
            name=$0;
            # Entferne den (usb-...) Teil und den nachfolgenden Doppelpunkt
            sub(/ \([^\)]+\):?$/, "", name);
            # Falls am Ende noch ein Doppelpunkt ist, auch den entfernen
            sub(/:$/, "", name);
        }
    '
}

# Funktion zum ÃberprÃžfen, ob ein GerÃĪt eine Android Webcam ist
is_android_webcam() {
    v4l2-ctl --device="$1" --all 2>/dev/null | grep -q "Android Webcam"
}

# Zentrale Rofi-MenÃž Definition
rofi_menu() {
    rofi -dmenu -i -location 0 -theme-str 'window { width: 50%; } listview { lines: 5; }' "$@"
}

# GerÃĪte auflisten und Auswahl treffen
selected=$(list_video_devices | rofi_menu -p "WÃĪhle Webcam:")

[ -z "$selected" ] && exit 0

# Extrahiere nur den /dev/video Pfad (das erste Wort)
DEVICE=$(echo "$selected" | awk '{print $1}')

# Konfiguriere das GerÃĪt basierend auf dem Typ
if is_android_webcam "$DEVICE"; then
    RESOLUTION=$ANDROID_RESOLUTION
    FILTERS=$ANDROID_FILTERS
    ROTATION=$ANDROID_ROTATION
else
    RESOLUTION=$STANDARD_RESOLUTION
    FILTERS=$STANDARD_FILTERS
    ROTATION=""
fi

# Setze die AuflÃķsung
WIDTH=$(echo "$RESOLUTION" | cut -d'x' -f1)
HEIGHT=$(echo "$RESOLUTION" | cut -d'x' -f2)

notify-send "Starte Webcam" "Kamera: $DEVICE\nAuflÃķsung: $RESOLUTION"

# AuflÃķsung setzen (lÃĪuft im Hintergrund, um nicht zu blockieren)
v4l2-ctl --set-fmt-video="width=$WIDTH,height=$HEIGHT,pixelformat=$PIXELFORMAT" --device="$DEVICE" >/dev/null 2>&1

# Starte MPV mit den konfigurierten Optionen
nice -n 10 mpv $MPV_BASE_OPTIONS $ROTATION --vf="$FILTERS" "$DEVICE" >/dev/null 2>&1
