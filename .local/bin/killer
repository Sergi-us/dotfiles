#!/bin/sh
## 2025-02-10 SARBS
# Ein Skript zum Auswählen und Beenden (Killen) von Benutzerprozessen via Rofi.
# Listet Prozesse sortiert nach Speicherauslastung auf.

rofi_menu() {
    rofi -dmenu -i -location 0 -theme-str 'window { width: 60%; } listview { lines: 20; }' "$@"
}

# 1. 'ps' holt die Prozesse des aktuellen Nutzers (PID, Memory %, CPU %, Befehl)
# 2. 'sort' sortiert sie nach der 2. Spalte (Memory %) absteigend (-r)
# 3. 'sed' entfernt die unschöne Überschriftenzeile von ps
# 4. 'rofi' zeigt die Liste an
# 5. 'awk' holt sich am Ende nur die PID (das erste Feld) aus der ausgewählten Zeile
selected=$(ps -u "$USER" -o pid,%mem,%cpu,comm | sort -b -k2 -r | sed -n '1!p' | rofi_menu -p "Prozess beenden (PID | MEM% | CPU% | CMD):")

[ -z "$selected" ] && exit 0

# Extrahiere die PID und den Prozessnamen für die Benachrichtigung
pid=$(echo "$selected" | awk '{print $1}')
pname=$(echo "$selected" | awk '{print $4}')

# Versuche den Prozess nett (SIGTERM/15) zu beenden
if kill -15 "$pid" >/dev/null 2>&1; then
    notify-send " Prozess beendet" "Der Prozess '$pname' (PID: $pid) wurde beendet.\n- du Monster 👾"
else
    # Falls das fehlschlägt (z.B. weil der Prozess schon weg ist)
    notify-send -u critical "Fehler" "Konnte Prozess '$pname' (PID: $pid) nicht beenden."
fi
