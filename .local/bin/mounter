#!/bin/bash
## 2026-05-10   SARBS core DEV
# Abhängigkeiten: GNU Coreutils, find, iconv, lsblk, mountpoint, notify-send, rofi, sed, simple-mtpfs, udisks2 (udisksctl)
## 2025-08-29   SARBS - ASCII-Marker mit Phyton parsing
## Mountet Android-Telefone und USB-Laufwerke (verschlüsselt oder nicht)
## WICHTIG: Nutzt ASCII-Marker [TYPE] statt Emojis für Portabilität!
## Die Marker bestimmen die Mount-Logik und Optionen.
## Dependencies: dmenu, simple-mtpfs (für Android), cryptsetup (für LUKS)

IFS='
'

# Funktion zum Escapen von Handy-Namen für sichere Filesystem-Namen
# Entfernt Sonderzeichen und konvertiert zu ASCII
escape() {
    echo "$@" | iconv -cf UTF-8 -t ASCII//TRANSLIT | tr -d '[:punct:]' | tr '[:upper:]' | tr ' ' '-' | sed "s/-\+/-/g;s/\(^-\|-\$\)//g"
}

# Gerätetyp-Erkennung basierend auf Device-Namen und System-Info
# Returnt: NVME, DVD, USB, SSD, HDD oder DISK
get_device_type() {
    local device="$1"
    local base="${device##*/}"  # Nur der Device-Name ohne /dev/

    # NVMe-SSDs erkennen (z.B. nvme0n1p1)
    [[ "$base" =~ nvme ]] && echo "NVME" && return

    # Optische Laufwerke (sr0, sr1, etc.)
    [[ "$base" =~ sr[0-9]+ ]] && echo "DVD" && return

    # Basis-Device für weitere Checks vorbereiten
    # Bei NVMe: nvme0n1p1 -> nvme0n1, bei anderen: sda1 -> sda
    [[ "$base" =~ nvme[0-9]+n[0-9]+p[0-9]+ ]] && base="${base%p[0-9]*}" || base="${base%[0-9]*}"

    # Check ob rotational (HDD) oder nicht (SSD) via /sys
    if [ -f "/sys/block/$base/queue/rotational" ]; then
        rot=$(cat "/sys/block/$base/queue/rotational" 2>/dev/null || echo "1")      # 0=SSD, 1=HDD
        rem=$(cat "/sys/block/$base/removable" 2>/dev/null || echo "0")  # 1=USB
        [ "$rem" = "1" ] && echo "USB" && return
        [ "$rot" = "0" ] && echo "SSD" || echo "HDD"
    else
        echo "DISK"  # Fallback wenn keine Info verfügbar
    fi
}

# Menü-Befehl definieren (Zentrale Stelle für einfache Anpassungen)
rofi_menu() {
    rofi -dmenu -i -location 0 -theme-str 'window { width: 50%; } listview { lines: 7; }' "$@"
}

# ========== ANDROID/MTP DEVICES ==========
# Listet alle MTP-Geräte und markiert sie mit [HANDY]
phones="$(simple-mtpfs -l 2>/dev/null | sed "s/^/[HANDY] /")"

# Bereits gemountete Handys aus der Liste entfernen
mountedphones="$(grep "simple-mtpfs" /etc/mtab)"
[ -n "$mountedphones" ] && phones="$(for phone in $phones; do
    escphone="$(escape "${phone#*] }")"
    echo "$mountedphones" | grep -q "$escphone" || echo "$phone"
done)"

# ========== LUKS ENCRYPTED DRIVES ==========
# Alle LUKS-Laufwerke finden (nutze -P für robustes Parsing bei leeren Spalten)
allluks="$(lsblk -Ppo name,type,size,label,mountpoint,fstype,uuid 2>/dev/null | grep 'FSTYPE="crypto_LUKS"')"

# Bereits entschlüsselte LUKS devices finden
decrypted="$(find /dev/disk/by-id/dm-uuid-CRYPT-LUKS2-* 2>/dev/null | sed "s|.*LUKS2-||;s|-.*||")"

# Nur nicht-entschlüsselte LUKS anzeigen
unopenedluks="$(echo "$allluks" | while read -r line; do
    [ -z "$line" ] && continue
    # Sicheres extrahieren der Werte (Grep/Sed mit präzisen Key-Matches, nicht greedy!)
    uuid=$(echo "$line" | grep -o ' UUID="[^"]*"' | sed 's/ UUID="//;s/"$//')
    name=$(echo "$line" | grep -o 'NAME="[^"]*"' | sed 's/NAME="//;s/"$//')
    size=$(echo "$line" | grep -o ' SIZE="[^"]*"' | sed 's/ SIZE="//;s/"$//')
    label=$(echo "$line" | grep -o ' LABEL="[^"]*"' | sed 's/ LABEL="//;s/"$//')

    uuid_clean="${uuid//-/}"  # Bindestriche aus UUID entfernen für Vergleich

    # Skip wenn bereits entschlüsselt
    if [ -n "$decrypted" ] && [ -n "$uuid_clean" ]; then
        echo "$decrypted" | grep -q "$uuid_clean" && continue
    fi

    printf "[LUKS ] %s (%s) %s\n" "$name" "$size" "$label"
done)"

# ========== NORMALE PARTITIONEN ==========
# Um 'leere' USB-Sticks (wie /dev/sda ohne Partitionen) zu finden, lassen wir lsblk prüfen ob sie Kinder (Partitionen) haben.
# --tree oder -l mit lsblk listet uns alles. Mit `lsblk -d` können wir sehen ob eine Disk roh formatiert ist, aber
# der sicherste Weg in awk/grep ist es, einfach alle "disk" Typen mit aufzunehmen, die NICHT root-devices für "part" sind.
# Wir lösen es einfach: Alles was "part", "rom", "crypt" ist ODER "disk" ABER wir filtern später die Disks raus,
# von denen wir wissen, dass sie Partitionen haben.
disks_with_parts=$(lsblk -rnpo pkname 2>/dev/null | grep -v "^$" | sort -u)

normalparts="$(lsblk -Ppo name,type,size,label,mountpoint,fstype,uuid 2>/dev/null | grep -v 'FSTYPE="crypto_LUKS"' | while read -r line; do
    [ -z "$line" ] && continue
    name=$(echo "$line" | grep -o 'NAME="[^"]*"' | sed 's/NAME="//;s/"$//')
    type=$(echo "$line" | grep -o ' TYPE="[^"]*"' | sed 's/ TYPE="//;s/"$//')
    size=$(echo "$line" | grep -o ' SIZE="[^"]*"' | sed 's/ SIZE="//;s/"$//')
    label=$(echo "$line" | grep -o ' LABEL="[^"]*"' | sed 's/ LABEL="//;s/"$//')
    fstype=$(echo "$line" | grep -o ' FSTYPE="[^"]*"' | sed 's/ FSTYPE="//;s/"$//')

    # lsblk version check: neueres lsblk nutzt oft MOUNTPOINTS statt MOUNTPOINT
    mountpoint=$(echo "$line" | grep -o ' MOUNTPOINT="[^"]*"' | sed 's/ MOUNTPOINT="//;s/"$//')
    [ -z "$mountpoint" ] && mountpoint=$(echo "$line" | grep -o ' MOUNTPOINTS="[^"]*"' | sed 's/ MOUNTPOINTS="//;s/"$//')

    # Ist es eine "disk", aber sie hat Partitionen? (Dann überspringen wir die "disk", da wir nur die "part"s mounten wollen)
    if [ "$type" = "disk" ]; then
        echo "$disks_with_parts" | grep -q "^$name$" && continue
    fi

    # Wir suchen nach ungemounteten Partitionen ("part"), optischen Medien ("rom"),
    # entschlüsselten LUKS Containern ("crypt")
    # ODER puren Disks ("disk"), die den obigen Check überlebt haben (also keine Partitionen drunter haben, wie /dev/sda!)
    if [ -z "$mountpoint" ] && { [ "$type" = "part" ] || [ "$type" = "rom" ] || [ "$type" = "crypt" ] || [ "$type" = "disk" ]; }; then
        dtype=$(get_device_type "$name")
        desc="${label:-${fstype:-${name##*/}}}"
        printf "[%-5s] %s (%s) %s\n" "$dtype" "$name" "$size" "$desc"
    fi
done)"

# ========== ALLES ZUSAMMENFÜGEN ==========
alldrives="$(echo "$phones
$unopenedluks
$normalparts" | sed "/^$/d")"  # Leere Zeilen entfernen

# Beende wenn keine Laufwerke gefunden
if [ -z "$alldrives" ]; then
    notify-send "ℹ️ Info" "Keine unmounted Laufwerke gefunden"
    exit 0
fi

# ========== ROFI AUSWAHL ==========
chosen="$(echo "$alldrives" | rofi_menu -p "Welches Laufwerk mounten?")"
[ -z "$chosen" ] && exit 0

# ========== PARSE DIE AUSWAHL ==========
# Der Marker [TYPE] bestimmt die Mount-Logik!
marker="${chosen%%]*}"         # Alles vor ]
marker="${marker#[}"           # [ entfernen
marker="${marker// /}"         # Spaces entfernen

# Device-Pfad ist zwischen "] " und " ("
device="${chosen#*] }"         # Alles nach "] "
device="${device%% (*}"        # Alles vor " ("

# ========== HILFSFUNKTIONEN ==========

# Mountpunkt via Rofi wählen lassen
getmount() {
    mp="$(find $HOME/Mounts $HOME /mnt /media /mount -maxdepth 1 -type d 2>/dev/null | rofi_menu -p "Mountpunkt wählen:")"
    test -n "$mp"
    if [ ! -d "$mp" ]; then
        mkdiryn=$(printf "Nein\\nJa" | rofi_menu -p "$mp existiert nicht. Erstellen?")
        # DEV-Modus: sudo entfernt, läuft komplett als normaler User!
        # [ "$mkdiryn" = "Ja" ] && (mkdir -p "$mp" || sudo -A mkdir -p "$mp")
        [ "$mkdiryn" = "Ja" ] && mkdir -p "$mp"
    fi
}

# Versuche mount ohne spezifischen Mountpunkt (nutzt fstab wenn vorhanden)
attemptmount() {
    # DEV-Modus: udisksctl statt sudo mount für fstab-Einträge
    # if sudo -A mount "$1" 2>/dev/null; then
    if udisksctl mount -b "$1" 2>/dev/null; then
        notify-send "✔ Laufwerk gemountet" "$1 gemountet."
        exit
    else
        return 1
    fi
}

# ========== HAUPTLOGIK - Marker-basierte Aktionen ==========
case "$marker" in
    HDD|SSD|USB|NVME|DVD|DISK)
        # <<< DEV-Modus Start: udisksctl statt sudo mount >>>
        # Vorteil: udisksctl nutzt den Udisks2-Daemon via Polkit. Keine sudo-Rechte nötig.
        # Mountpoints werden automatisch unter /run/media/$USER/ erstellt.
        # Berechtigungen (uid/gid) werden vom System automatisch korrekt gesetzt.
        if attemptmount "$device"; then
            exit
        else
            if udisksctl mount -b "$device"; then
                notify-send "✔ $marker gemountet" "$device erfolgreich via udisksctl gemountet."
                exit 0
            else
                notify-send "✗ Fehler" "udisksctl mount fehlgeschlagen für $device"
                exit 1
            fi
        fi

        # --- Alter Sudo-Code auskommentiert ---
        # # Normale Laufwerke
        # if attemptmount "$device"; then
        #     exit
        # else
        #     getmount
        # 
        #     # Dateisystem des Geräts erkennen (entscheidet über die Mount-Optionen!)
        #     devfs=$(lsblk -no fstype "$device" 2>/dev/null | head -n1)
        #     [ -z "$devfs" ] && devfs=$(sudo -A blkid -s TYPE -o value "$device" 2>/dev/null)
        # 
        #     case "$devfs" in
        #         vfat|exfat|ntfs|ntfs3)
        #             case "$marker" in
        #                 USB|HDD) opts="uid=$(id -u),gid=$(id -g),sync" ;;
        #                 SSD|NVME) opts="uid=$(id -u),gid=$(id -g),noatime" ;;
        #                 DVD) opts="ro,uid=$(id -u),gid=$(id -g)" ;;
        #                 *) opts="uid=$(id -u),gid=$(id -g)" ;;
        #             esac
        #             sudo -A mount "$device" "$mp" -o "$opts" || {
        #                 notify-send "✗ Fehler" "Mount fehlgeschlagen für $device ($devfs)"
        #                 exit 1
        #             }
        #             ;;
        #         *)
        #             sudo -A mount "$device" "$mp" || {
        #                 notify-send "✗ Fehler" "Mount fehlgeschlagen für $device ($devfs)"
        #                 exit 1
        #             }
        #             sudo -A chown "$(id -u):$(id -g)" "$mp"
        #             ;;
        #     esac
        # 
        #     notify-send "✔ $marker gemountet" "$device ($devfs) zu $mp gemountet."
        # fi
        # <<< DEV-Modus Ende >>>
        ;;

    LUKS)
        # <<< DEV-Modus Start: udisksctl für LUKS >>>
        # Vorteil: udisksctl verwaltet das Mapping automatisch. Entschlüsseltes Laufwerk
        # kann danach mit einem weiteren udisksctl-Aufruf normal gemountet werden.
        lukspw=$(rofi -dmenu -password -p "LUKS Passwort für ${device##*/}: " \
            -theme-str 'window { width: 30%; padding: 2%; } mainbox { children: [prompt, entry]; } listview { enabled: false; }')

        [ -z "$lukspw" ] && exit 0

        # Entschlüsseln via udisksctl. --key-file=- liest von stdin (via printf)
        if ! unlock_out=$(printf "%s" "$lukspw" | udisksctl unlock -b "$device" --key-file=- 2>&1); then
            notify-send "✗ Entschlüsselung fehlgeschlagen" "${unlock_out:-Unbekannter Fehler}"
            lukspw=""
            exit 1
        fi
        lukspw=""

        # udisksctl gibt den Pfad des gemappten Devices aus: "Unlocked /dev/sdX1 as /dev/dm-0."
        # Wir extrahieren das /dev/dm-X Device, um es direkt mounten zu können.
        mapped_device=$(echo "$unlock_out" | grep -o '/dev/dm-[0-9]*' | head -n1)

        if [ -n "$mapped_device" ]; then
            if udisksctl mount -b "$mapped_device"; then
                notify-send "✔ LUKS gemountet" "Erfolgreich via udisksctl entschlüsselt und gemountet."
            else
                notify-send "✗ Fehler" "Mount des entschlüsselten Laufwerks fehlgeschlagen."
                udisksctl lock -b "$device" # Bei Fehler gleich wieder aufräumen
                exit 1
            fi
        else
            notify-send "✗ Fehler" "Konnte gemapptes LUKS-Device nicht ermitteln."
            exit 1
        fi

        # --- Alter Sudo-Code auskommentiert ---
        # # Verschlüsselte Laufwerke - automatisch nach /mnt/usb[num]
        # num=0
        # while [ -e "/dev/mapper/usb$num" ]; do
        #     num=$((num + 1))
        # done
        # 
        # lukspw=$(rofi -dmenu -password -p "LUKS Passwort für ${device##*/}: " \
        #     -theme-str 'window { width: 30%; padding: 2%; } mainbox { children: [prompt, entry]; } listview { enabled: false; }')
        # 
        # [ -z "$lukspw" ] && exit 0
        # 
        # if ! error_msg=$(printf "%s" "$lukspw" | sudo -A cryptsetup open --key-file=- "$device" "usb$num" 2>&1); then
        #     notify-send "✗ Entschlüsselung fehlgeschlagen" "${error_msg:-Unbekannter Fehler}"
        #     lukspw=""
        #     exit 1
        # fi
        # lukspw=""
        # 
        # sleep 0.5
        # 
        # if [ -b "/dev/mapper/usb$num" ]; then
        #     mp="/mnt/usb$num"
        #     [ ! -d "$mp" ] && sudo -A mkdir -p "$mp"
        # 
        #     luks_fs=$(lsblk -no fstype "/dev/mapper/usb$num" 2>/dev/null | head -n1)
        # 
        #     case "$luks_fs" in
        #         vfat|exfat|ntfs|ntfs3)
        #             sudo -A mount -o "uid=$(id -u),gid=$(id -g)" "/dev/mapper/usb$num" "$mp" ;;
        #         *)
        #             sudo -A mount "/dev/mapper/usb$num" "$mp" ;;
        #     esac || {
        #         notify-send "✗ Fehler" "Mount fehlgeschlagen ($luks_fs)"
        #         sudo -A cryptsetup close "usb$num"
        #         exit 1
        #     }
        #     case "$luks_fs" in ext4|btrfs|xfs|f2fs|"") sudo -A chown "$(id -u):$(id -g)" "$mp" ;; esac
        # 
        #     notify-send "✔ LUKS gemountet" "$device ($luks_fs) zu $mp gemountet."
        # else
        #     notify-send "✗ Fehler" "Konnte Block-Gerät /dev/mapper/usb$num nicht finden"
        #     exit 1
        # fi
        # <<< DEV-Modus Ende >>>
        ;;

    HANDY)
        # <<< DEV-Modus Start: Userspace MTP Mount >>>
        # simple-mtpfs als normaler User ausführen. Dadurch entfällt "allow_other" und 
        # die Berechtigungen stimmen automatisch für den User.
        notify-send "📱 Hinweis" "Erlaube Dateizugriff auf dem Handy"
        getmount

        # Device-Nummer aus der MTP-Liste extrahieren
        number="${chosen#*] }"
        number="${number%%:*}"

        # simple-mtpfs ohne sudo ausführen!
        simple-mtpfs \
            -o fsname="simple-mtpfs-$(escape "$chosen")" \
            --device "$number" "$mp" || {
            notify-send "✗ Fehler" "Mount fehlgeschlagen"
            exit 1
        }
        notify-send "✔ Handy gemountet" "Android zu $mp gemountet"

        # --- Alter Sudo-Code auskommentiert ---
        # # Android/MTP Geräte
        # notify-send "📱 Hinweis" "Erlaube Dateizugriff auf dem Handy"
        # getmount
        # 
        # number="${chosen#*] }"
        # number="${number%%:*}"
        # 
        # sudo -A simple-mtpfs -o allow_other \
        #     -o fsname="simple-mtpfs-$(escape "$chosen")" \
        #     --device "$number" "$mp" || {
        #     notify-send "✗ Fehler" "Mount fehlgeschlagen"
        #     exit 1
        # }
        # notify-send "✔ Handy gemountet" "Android zu $mp gemountet"
        # <<< DEV-Modus Ende >>>
        ;;

    *)
        # Unbekannter Marker - sollte nicht vorkommen
        notify-send "✗ Fehler" "Unbekannter Typ: $marker"
        exit 1
        ;;
esac
