#!/bin/sh
## 2025-09-26   SARBS - Multi-Platform Streaming
## 2026-03-07 - VAAPI-Support, dynamische Audio-Erkennung, 2 Audiospuren

# Stream Keys aus Dateien laden
YT_KEY="$(cat ~/.local/share/yt/stream-key 2>/dev/null)"
TW_KEY="$(cat ~/.local/share/twitch/stream-key 2>/dev/null)"
# FB_KEY="$(cat ~/.local/share/facebook/key 2>/dev/null)"
# TT_KEY="$(cat ~/.local/share/tiktok/key 2>/dev/null)"

# Aufloesung erkennen
AUFLOSUNG="${AUFLOSUNG:-$(xrandr 2>/dev/null | grep -oE "[0-9]+x[0-9]+" | head -n1)}"
AUFLOSUNG="${AUFLOSUNG:-1920x1080}"
FRAMERATE="30"

# Bitrate nach Aufloesung
case "${AUFLOSUNG}" in
    "3840x2160"|"2560x1440") VIDEO_BITRATE="5500k" ;;
    "1920x1080") VIDEO_BITRATE="4000k" ;;
    "1280x720") VIDEO_BITRATE="2500k" ;;
    *) VIDEO_BITRATE="3000k" ;;
esac

AUDIO_BITRATE="128k"
AUDIO_SAMPLERATE="48000"

# Lokale Aufzeichnung
LOCAL_RECORDING=true
RECORDING_DIR="${HOME}/Videos"
RECORDING_PATH="${RECORDING_DIR}/stream_$(date +%Y%m%d_%H%M%S).ts"

# --- Encoder-Erkennung: VAAPI bevorzugt, libx264 als Fallback ---

detect_encoder() {
    if [ -e /dev/dri/renderD128 ] && \
       ffmpeg -hide_banner -loglevel error -init_hw_device vaapi=va:/dev/dri/renderD128 \
              -f lavfi -i "nullsrc=s=256x256:d=0.1" \
              -vf 'format=nv12,hwupload' -c:v h264_vaapi -frames:v 1 \
              -f null - 2>/dev/null; then
        ENCODER="vaapi"
    else
        ENCODER="libx264"
    fi
}

detect_encoder

# --- Audio-Quellen dynamisch erkennen ---

# Systemaudio: Monitor-Quelle des Default-Sinks ermitteln
detect_system_audio() {
    DEFAULT_SINK="$(pactl get-default-sink 2>/dev/null)"
    if [ -n "${DEFAULT_SINK}" ]; then
        SYS_MONITOR="${DEFAULT_SINK}.monitor"
        if pactl list sources short 2>/dev/null | grep -q "${SYS_MONITOR}"; then
            return 0
        fi
    fi
    # Fallback: Erste verfuegbare .monitor-Quelle
    SYS_MONITOR="$(pactl list sources short 2>/dev/null | grep '\.monitor' | head -n1 | awk '{print $2}')"
    [ -n "${SYS_MONITOR}" ]
}

detect_system_audio
HAS_SYS=$?

# --- Status-Ausgabe ---

BUFSIZE_NUM=$((${VIDEO_BITRATE%k} * 2))

echo "Multi-Platform Stream"
echo "Aufloesung: ${AUFLOSUNG} @ ${FRAMERATE}fps | Bitrate: ${VIDEO_BITRATE}"
echo "Encoder: ${ENCODER}"
echo "Mikrofon: default (PulseAudio/PipeWire)"

if [ "${HAS_SYS}" -eq 0 ]; then
    echo "Systemaudio: ${SYS_MONITOR}"
else
    echo "WARNUNG: Keine Systemaudio-Quelle gefunden!"
    pactl list sources short 2>/dev/null | grep '\.monitor'
fi

# --- Stream-Ziele aufbauen ---

# Bei Mic+System: RTMP bekommt select (nur gemixtes Audio)
# Lokale Aufnahme bekommt select (separate Spuren)
# tee-Muxer: select braucht Quotes UND Backslash-Escaping fuer : und ,
if [ "${HAS_SYS}" -eq 0 ]; then
    RTMP_OPTS="select='v\:0\,a\:0':f=flv:onfail=ignore"
    REC_OPTS="select='v\:0\,a\:1\,a\:2':f=mpegts"
else
    RTMP_OPTS="f=flv:onfail=ignore"
    REC_OPTS="f=mpegts"
fi

TEE_OUTPUTS=""

echo ""
echo "Aktive Ziele:"
if [ -n "${YT_KEY}" ]; then
    echo "  YouTube"
    TEE_OUTPUTS="${TEE_OUTPUTS}[${RTMP_OPTS}]rtmp://x.rtmp.youtube.com/live2/${YT_KEY}|"
fi

if [ -n "${TW_KEY}" ]; then
    echo "  Twitch"
    TEE_OUTPUTS="${TEE_OUTPUTS}[${RTMP_OPTS}]rtmp://live.twitch.tv/live/${TW_KEY}|"
fi

if [ -n "${FB_KEY}" ]; then
    echo "  Facebook"
    TEE_OUTPUTS="${TEE_OUTPUTS}[${RTMP_OPTS}]rtmp://live-api-s.facebook.com/rtmp/${FB_KEY}|"
fi

if [ -n "${TT_KEY}" ]; then
    echo "  TikTok"
    TEE_OUTPUTS="${TEE_OUTPUTS}[${RTMP_OPTS}]rtmp://live.tiktok.com/live/${TT_KEY}|"
fi

# Lokale Aufnahme als tee-Ziel
if [ "${LOCAL_RECORDING}" = true ]; then
    mkdir -p "${RECORDING_DIR}"
    echo "  Aufzeichnung: ${RECORDING_PATH##*/}"
    TEE_OUTPUTS="${TEE_OUTPUTS}[${REC_OPTS}]${RECORDING_PATH}"
else
    TEE_OUTPUTS="${TEE_OUTPUTS%|}"
fi

if [ -z "${TEE_OUTPUTS}" ]; then
    echo "FEHLER: Weder Stream-Ziele noch lokale Aufnahme aktiv. Abbruch."
    exit 1
fi

echo ""
echo "Streaming... (Ctrl+C zum Beenden)"
echo ""

# --- ffmpeg-Kommando zusammenbauen ---
#
# Audio-Layout im Output:
#   a:0 = gemixtes Audio (Mic+System, aac) -> fuer RTMP-Streams
#   a:1 = Mikrofon roh (flac) -> fuer lokale Aufnahme
#   a:2 = Systemaudio roh (flac) -> fuer lokale Aufnahme
#
# Bei nur einer Audioquelle gibt es nur a:0 (kein Mix noetig)

if [ "${HAS_SYS}" -eq 0 ]; then
    # --- Mic + Systemaudio ---

    if [ "${ENCODER}" = "vaapi" ]; then
        FILTER="[0:v]format=nv12,hwupload[vout];[1:a]volume=1.0,aformat=sample_rates=${AUDIO_SAMPLERATE}[mic];[2:a]volume=0.8,aformat=sample_rates=${AUDIO_SAMPLERATE}[sys];[mic][sys]amix=inputs=2:normalize=0[mixed]"

        ffmpeg -hide_banner -loglevel warning -stats \
          -probesize 10M \
          -vaapi_device /dev/dri/renderD128 \
          -f x11grab -r "${FRAMERATE}" -s "${AUFLOSUNG}" -i "${DISPLAY:-:0.0}" \
          -f pulse -i default \
          -f pulse -i "${SYS_MONITOR}" \
          -filter_complex "${FILTER}" \
          -map "[vout]" -map "[mixed]" -map 1:a -map 2:a \
          -c:v h264_vaapi -b:v "${VIDEO_BITRATE}" -maxrate "${VIDEO_BITRATE}" -bufsize "${BUFSIZE_NUM}k" \
          -profile:v high -g 60 \
          -c:a:0 aac -ar "${AUDIO_SAMPLERATE}" -b:a:0 "${AUDIO_BITRATE}" \
          -c:a:1 aac -ar "${AUDIO_SAMPLERATE}" -b:a:1 320k \
          -c:a:2 aac -ar "${AUDIO_SAMPLERATE}" -b:a:2 320k \
          -f tee "${TEE_OUTPUTS}"
    else
        FILTER="[1:a]volume=1.0,aformat=sample_rates=${AUDIO_SAMPLERATE}[mic];[2:a]volume=0.8,aformat=sample_rates=${AUDIO_SAMPLERATE}[sys];[mic][sys]amix=inputs=2:normalize=0[mixed]"

        ffmpeg -hide_banner -loglevel warning -stats \
          -probesize 10M \
          -f x11grab -r "${FRAMERATE}" -s "${AUFLOSUNG}" -i "${DISPLAY:-:0.0}" \
          -f pulse -i default \
          -f pulse -i "${SYS_MONITOR}" \
          -filter_complex "${FILTER}" \
          -map 0:v -map "[mixed]" -map 1:a -map 2:a \
          -c:v libx264 -preset veryfast -pix_fmt yuv420p \
          -maxrate "${VIDEO_BITRATE}" -bufsize "${BUFSIZE_NUM}k" -g 60 -keyint_min 60 \
          -c:a:0 aac -ar "${AUDIO_SAMPLERATE}" -b:a:0 "${AUDIO_BITRATE}" \
          -c:a:1 aac -ar "${AUDIO_SAMPLERATE}" -b:a:1 320k \
          -c:a:2 aac -ar "${AUDIO_SAMPLERATE}" -b:a:2 320k \
          -f tee "${TEE_OUTPUTS}"
    fi

else
    # --- Nur Mikrofon (kein Systemaudio) ---

    if [ "${ENCODER}" = "vaapi" ]; then
        FILTER="[0:v]format=nv12,hwupload[vout]"

        ffmpeg -hide_banner -loglevel warning -stats \
          -probesize 10M \
          -vaapi_device /dev/dri/renderD128 \
          -f x11grab -r "${FRAMERATE}" -s "${AUFLOSUNG}" -i "${DISPLAY:-:0.0}" \
          -f pulse -i default \
          -filter_complex "${FILTER}" \
          -map "[vout]" -map 1:a \
          -c:v h264_vaapi -b:v "${VIDEO_BITRATE}" -maxrate "${VIDEO_BITRATE}" -bufsize "${BUFSIZE_NUM}k" \
          -profile:v high -g 60 \
          -c:a aac -ar "${AUDIO_SAMPLERATE}" -b:a "${AUDIO_BITRATE}" \
          -f tee "${TEE_OUTPUTS}"
    else
        ffmpeg -hide_banner -loglevel warning -stats \
          -probesize 10M \
          -f x11grab -r "${FRAMERATE}" -s "${AUFLOSUNG}" -i "${DISPLAY:-:0.0}" \
          -f pulse -i default \
          -map 0:v -map 1:a \
          -c:v libx264 -preset veryfast -pix_fmt yuv420p \
          -maxrate "${VIDEO_BITRATE}" -bufsize "${BUFSIZE_NUM}k" -g 60 -keyint_min 60 \
          -c:a aac -ar "${AUDIO_SAMPLERATE}" -b:a "${AUDIO_BITRATE}" \
          -f tee "${TEE_OUTPUTS}"
    fi
fi

echo ""
echo "Stream beendet."
