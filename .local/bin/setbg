#!/bin/sh
## 2025-11-28   SARBS

# Dieses Skript macht Folgendes:
#	Ohne Argumente: Setzt das Hintergrundbild (beim X-Start).
#	Mit einer Datei: Setzt diese als neues Hintergrundbild.
#	Mit einem Verzeichnis: Wählt eine zufällige Datei daraus.
#	Falls wal installiert ist, wird auch ein Farbschema generiert.

# Speicherort des Links zum Hintergrundbild.
bgloc="${XDG_DATA_HOME:-$HOME/.local/share}/bg"

# Konfigurationsdateien von Anwendungen, deren Themes durch pywal geändert werden.
dunstconf="${XDG_CONFIG_HOME:-$HOME/.config}/dunst/dunstrc"
zathuraconf="${XDG_CONFIG_HOME:-$HOME/.config}/zathura/zathurarc"

# Übergebe -s als Parameter, um Benachrichtigungen stumm zu schalten.
while getopts "s" o; do case "${o}" in
	s) silent='1' ;;
esac done

shift $((OPTIND - 1))

trueloc="$(readlink -f "$1")" &&
case "$(file --mime-type -b "$trueloc")" in
	image/* ) ln -sf "$trueloc" "$bgloc" ; bgmsg="ändere Hintergrundbild..." ;;
	inode/directory ) ln -sf "$(find "$trueloc" -iregex '.*.\(jpg\|jpeg\|png\|gif\)' -type f | shuf -n 1)" "$bgloc" ; bgmsg="zufälliges Hintergrundbild gewählt." ;;
	*) [ -z "$silent" ] && notify-send " Fehler" "kein gültiges Bild oder Verzeichnis." ; exit 1;;
esac

# Falls hellwal installiert ist, benutze es.
if command -v hellwal >/dev/null 2>&1 ; then
	hellwal_opts="--dark"

	if command -v magick >/dev/null 2>&1 ; then
		# Auflösung für die Analyse: Je kleiner, desto schneller. Je größer, desto genauer.
		sample_size="300x300"
		mean=$(magick "$(readlink -f "$bgloc")" -resize "$sample_size" -format "%[fx:mean]" info: 2>/dev/null)
	elif command -v convert >/dev/null 2>&1 ; then
		sample_size="300x300"
		mean=$(convert "$(readlink -f "$bgloc")" -resize "$sample_size" -format "%[fx:mean]" info: 2>/dev/null)
	fi

	if [ -n "$mean" ] && command -v bc >/dev/null 2>&1 ; then
		# Dynamische Kontrastanpassung bei dunklen Bildern
		if [ "$(echo "$mean < 0.35" | bc -l)" -eq 1 ]; then
			hellwal_opts="$hellwal_opts --check-contrast -b 0.9"
		elif [ "$(echo "$mean < 0.55" | bc -l)" -eq 1 ]; then
			hellwal_opts="$hellwal_opts --check-contrast -b 0.7"
		else
			hellwal_opts="$hellwal_opts --check-contrast"
		fi
	else
		hellwal_opts="$hellwal_opts --check-contrast"
	fi

	hellwal -i "$(readlink -f "$bgloc")" $hellwal_opts -o ~/.cache/wal/ -s "${XDG_CONFIG_HOME:-$HOME/.config}/hellwal/postrun" -q
# Weiche auf pywal aus, falls hellwal nicht verfügbar ist
elif command -v wal >/dev/null 2>&1 ; then
	wal -n -i "$(readlink -f $bgloc)" -o "${XDG_CONFIG_HOME:-$HOME/.config}/wal/postrun" >/dev/null 2>&1
# Falls keines installiert ist, stelle Konfigurationsdateien wieder her.
else
	[ -f "$dunstconf.bak" ] && unlink "$dunstconf" && mv "$dunstconf.bak" "$dunstconf"
	[ -f "$zathuraconf.bak" ] && unlink "$zathuraconf" && mv "$zathuraconf.bak" "$zathuraconf"
fi

# ändert das Theme für Telegram und legt es in ~/.cache/walogram/wal.tdesktop-theme ab
# walogram -B -i ~/.local/share/bg >/dev/null 2>&1
# walogram -i ~/.local/share/bg >/dev/null 2>&1

xwallpaper --zoom "$bgloc"
# Falls dwm läuft, sende Signal zum Aktualisieren des Farbschemas.
# pidof dwm >/dev/null && xdotool key super+F5
pidof dwm >/dev/null && kill -USR1 $(pidof dwm)

# Notification NACH hellwal/postrun senden, damit dunst-Neustart sie nicht killt
[ -z "$silent" ] && [ -n "$bgmsg" ] && notify-send -i "$bgloc" "$bgmsg"
