#!/bin/sh
# 2026-03-07 SARBS
# Persistente Zwischenablage mit rofi
# Ersetzt das alte cliphist-Skript und die vorherige clipctl-Version.
#
# Abhängigkeiten: xclip, rofi
#
# Ablauf:
#   Mod+c  → clipctl copy    Aktuelle X11-Zwischenablage in Historie speichern
#   Mod+v  → clipctl paste   Eintrag aus Historie wählen (rofi) → in CLIPBOARD legen
#   Mod+x  → clipctl manage  Historie verwalten: löschen, leeren
#
# Datei-Operationen (für lf-Integration):
#   clipctl file-copy <pfade>  - Dateien zum Kopieren vormerken
#   clipctl file-cut <pfade>   - Dateien zum Verschieben vormerken
#   clipctl file-paste [ziel]  - Vorgemerkte Dateien einfügen
#   clipctl clip-paste [ziel]  - Zwischenablage als Datei speichern (Bilder, Text)

HISTFILE="${XDG_DATA_HOME:-$HOME/.local/share}/sarbs/cliphist"
PLACEHOLDER="<NEWLINE>"
FILESTAGE="/tmp/clipctl-files"

# Histfile anlegen falls nicht vorhanden
[ -d "$(dirname "$HISTFILE")" ] || mkdir -p "$(dirname "$HISTFILE")"
[ -f "$HISTFILE" ] || touch "$HISTFILE"

# --- Text-Aktionen ---

# Aktuelle Zwischenablage (PRIMARY + CLIPBOARD) in Historie speichern
do_copy() {
	# PRIMARY nach CLIPBOARD syncen (Terminal-Markierungen)
	xclip -o -selection primary 2>/dev/null | xclip -i -selection clipboard 2>/dev/null
	clip=$(xclip -o -selection clipboard 2>/dev/null)
	[ -z "$clip" ] && notify-send "Clipboard" "Zwischenablage ist leer" && return 0

	# Mehrzeiler als einzeiligen Eintrag speichern (Newlines → Placeholder)
	entry=$(printf '%s' "$clip" | sed ':a;N;$!ba;s/\n/'"$PLACEHOLDER"'/g')

	# Vorschau kürzen (max. 80 Zeichen)
	preview=$(printf '%.80s' "$clip")
	[ ${#clip} -gt 80 ] && preview="${preview}…"

	# Duplikat-Prüfung
	if grep -Fxq "$entry" "$HISTFILE" 2>/dev/null; then
		notify-send "Clipboard" "Bereits vorhanden:\n$preview"
		return 0
	fi

	printf '%s\n' "$entry" >> "$HISTFILE"
	notify-send "Clipboard" "Gespeichert:\n$preview"
}

# Eintrag aus Historie wählen und in CLIPBOARD legen
do_paste() {
	[ ! -s "$HISTFILE" ] && notify-send  "Clipboard" "Historie ist leer" && return 0

	# Neueste Einträge oben anzeigen
	selection=$(tac "$HISTFILE" | rofi -dmenu -i -p "Einfügen:" -l 15) || return 0

	# Placeholder zurück in Newlines wandeln und in CLIPBOARD legen
	printf '%s' "$selection" | sed "s/$PLACEHOLDER/\n/g" | xclip -i -selection clipboard
	notify-send  "Clipboard" "In Zwischenablage"
}

# Historie verwalten: Einträge löschen, alles leeren
do_manage() {
	choice=$(printf "Eintrag löschen\nHistorie leeren\nZwischenablage leeren\nAbbrechen" | \
		rofi -dmenu -i -p "Verwalten:")

	case "$choice" in
		"Eintrag löschen")
			[ ! -s "$HISTFILE" ] && notify-send "Clipboard" "Historie ist leer" && return 0
			selection=$(tac "$HISTFILE" | rofi -dmenu -i -p "Löschen:" -l 15) || return 0
			[ -n "$selection" ] || return 0
			grep -Fxv "$selection" "$HISTFILE" > "${HISTFILE}.tmp"
			mv "${HISTFILE}.tmp" "$HISTFILE"
			notify-send  "Clipboard" "Eintrag gelöscht"
			;;
		"Historie leeren")
			confirm=$(printf "Nein\nJa" | \
				rofi -dmenu -i -p "Gesamte persistente Historie unwiderruflich löschen?")
			[ "$confirm" = "Ja" ] || return 0
			: > "$HISTFILE"
			notify-send  "Clipboard" "Historie geleert"
			;;
		"Zwischenablage leeren")
			printf '' | xclip -i -selection primary 2>/dev/null
			printf '' | xclip -i -selection clipboard 2>/dev/null
			notify-send  "Clipboard" "Zwischenablage geleert"
			;;
		*) return 0 ;;
	esac
}

# --- Datei-Aktionen (lf-Integration) ---

# Dateien zum Kopieren vormerken
do_file_copy() {
	shift
	if [ $# -gt 0 ]; then
		printf "copy\n" > "$FILESTAGE"
		for f in "$@"; do printf "%s\n" "$f" >> "$FILESTAGE"; done
	else
		printf "copy\n" > "$FILESTAGE"
		cat >> "$FILESTAGE"
	fi
	count=$(($(wc -l < "$FILESTAGE") - 1))
	notify-send  "Clipboard" "$count Datei(en) zum Kopieren vorgemerkt"
}

# Dateien zum Verschieben vormerken
do_file_cut() {
	shift
	if [ $# -gt 0 ]; then
		printf "cut\n" > "$FILESTAGE"
		for f in "$@"; do printf "%s\n" "$f" >> "$FILESTAGE"; done
	else
		printf "cut\n" > "$FILESTAGE"
		cat >> "$FILESTAGE"
	fi
	count=$(($(wc -l < "$FILESTAGE") - 1))
	notify-send  "Clipboard" "$count Datei(en) zum Verschieben vorgemerkt"
}

# Vorgemerkte Dateien ins Zielverzeichnis einfügen
do_file_paste() {
	[ ! -f "$FILESTAGE" ] && notify-send  "Clipboard" "Keine Dateien vorgemerkt" && return 1

	mode=$(head -1 "$FILESTAGE")
	files=$(tail -n +2 "$FILESTAGE")
	dest="${2:-.}"

	echo "$files" | while IFS= read -r src; do
		[ -z "$src" ] && continue
		[ ! -e "$src" ] && notify-send -t 3000 "Clipboard" "Nicht gefunden: $src" && continue
		basename=$(basename "$src")
		target="$dest/$basename"

		# Namenskollision vermeiden
		if [ -e "$target" ]; then
			i=1
			ext="${basename##*.}"
			name="${basename%.*}"
			if [ "$ext" = "$basename" ]; then
				while [ -e "$dest/${basename}_$i" ]; do i=$((i + 1)); done
				target="$dest/${basename}_$i"
			else
				while [ -e "$dest/${name}_$i.$ext" ]; do i=$((i + 1)); done
				target="$dest/${name}_$i.$ext"
			fi
		fi

		case "$mode" in
			copy) cp -r "$src" "$target" ;;
			cut)  mv "$src" "$target" ;;
		esac
	done

	case "$mode" in
		copy) notify-send  "Clipboard" "Dateien nach $dest kopiert" ;;
		cut)  notify-send  "Clipboard" "Dateien nach $dest verschoben"
		      rm -f "$FILESTAGE" ;;
	esac
}

# Zwischenablage-Inhalt als Datei speichern (Bilder, Text)
do_clip_paste() {
	dest="${2:-.}"
	timestamp=$(date '+%Y%m%d-%H%M%S')
	targets=$(xclip -o -selection clipboard -t TARGETS 2>/dev/null)

	if echo "$targets" | grep -q "image/png"; then
		outfile="$dest/clipboard-$timestamp.png"
		xclip -o -selection clipboard -t image/png > "$outfile" 2>/dev/null
		notify-send  "Clipboard" "Bild gespeichert: $(basename "$outfile")"
	elif echo "$targets" | grep -q "image/jpeg"; then
		outfile="$dest/clipboard-$timestamp.jpg"
		xclip -o -selection clipboard -t image/jpeg > "$outfile" 2>/dev/null
		notify-send  "Clipboard" "Bild gespeichert: $(basename "$outfile")"
	elif echo "$targets" | grep -q "image/bmp"; then
		outfile="$dest/clipboard-$timestamp.bmp"
		xclip -o -selection clipboard -t image/bmp > "$outfile" 2>/dev/null
		notify-send  "Clipboard" "Bild gespeichert: $(basename "$outfile")"
	else
		text=$(xclip -o -selection clipboard 2>/dev/null)
		if [ -n "$text" ]; then
			outfile="$dest/clipboard-$timestamp.txt"
			printf "%s" "$text" > "$outfile"
			notify-send  "Clipboard" "Text gespeichert: $(basename "$outfile")"
		else
			notify-send  "Clipboard" "Zwischenablage ist leer"
		fi
	fi
}

# --- Hauptlogik ---

case "$1" in
	copy)       do_copy ;;
	paste)      do_paste ;;
	manage)     do_manage ;;
	file-copy)  do_file_copy "$@" ;;
	file-cut)   do_file_cut "$@" ;;
	file-paste) do_file_paste "$@" ;;
	clip-paste) do_clip_paste "$@" ;;
	*)
		printf "clipctl - Persistente Zwischenablage\n\n"
		printf "Verwendung: clipctl <Aktion>\n\n"
		printf "Text-Aktionen:\n"
		printf "  copy    - Zwischenablage in Historie speichern\n"
		printf "  paste   - Aus Historie wählen (rofi) → CLIPBOARD\n"
		printf "  manage  - Historie verwalten (löschen, leeren)\n"
		printf "\nDatei-Aktionen (lf-Integration):\n"
		printf "  file-copy <pfade>  - Dateien zum Kopieren vormerken\n"
		printf "  file-cut <pfade>   - Dateien zum Verschieben vormerken\n"
		printf "  file-paste [ziel]  - Vorgemerkte Dateien einfügen\n"
		printf "  clip-paste [ziel]  - Zwischenablage als Datei speichern\n"
		exit 0
		;;
esac
